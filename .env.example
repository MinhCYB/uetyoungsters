# AI Worker owns the Gemini credential and provider configuration.
GEMINI_API_KEY=
DEFAULT_MODEL=
DEFAULT_MAX_TOKENS=2048
REQUEST_TIMEOUT_SECONDS=60

# Student Companion calls only the internal AI Worker HTTP gateway.
COMPANION_LLM_MODE=live
AI_WORKER_URL=http://ai-worker-service:8000
AI_WORKER_TIMEOUT_SECONDS=30
COMPANION_LLM_MAX_TOKENS=2048
COMPANION_LLM_FALLBACK_ENABLED=false
