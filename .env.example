# PostgreSQL schema used by crawl-service and backend-api.
CRAWL_DATABASE_SCHEMA=crawl

# Gemini configuration. Copy this file to .env and replace the key locally.
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_MODEL=gemini-3.1-flash-lite
TRANSLATION_MODEL=gemini-3.1-flash-lite
DEFAULT_MAX_TOKENS=8192
REQUEST_TIMEOUT_SECONDS=120

# Development authentication settings.
AUTH_SECRET=replace-this-with-a-long-random-secret
COOKIE_SECURE=false

# Optional until roadmap-service calls an external LLM directly.
LLM_API_KEY=
